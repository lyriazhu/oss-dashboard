# GitHub API Configuration
# COPY THIS FILE TO config.yaml AND ADD YOUR TOKEN

github:
  # Get your token from: https://github.com/settings/tokens
  # Required scopes: public_repo, read:org, read:user
  token: "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"
  
# Projects to track
# Two configuration formats are supported:
# 1. Single repo (backward compatible):
#    - name, owner, repo, github_url, foundation, website
# 2. Multiple repos (for projects with multiple repositories):
#    - name, repos (list of {owner, repo}), foundation, website
projects:
  - name: "Strimzi"
    github_url: "https://github.com/strimzi/strimzi-kafka-operator"
    owner: "strimzi"
    repo: "strimzi-kafka-operator"
    foundation: "CNCF"
    website: "https://strimzi.io"
    
  - name: "Apache Camel"
    github_url: "https://github.com/apache/camel"
    owner: "apache"
    repo: "camel"
    foundation: "Apache Software Foundation"
    website: "https://camel.apache.org"
    
  - name: "Apache Artemis"
    github_url: "https://github.com/apache/artemis"
    owner: "apache"
    repo: "artemis"
    foundation: "Apache Software Foundation"
    website: "https://activemq.apache.org/components/artemis/"
    issue_source: jira
    jira_project_key: ARTEMIS
    jira_base_url: "https://issues.apache.org/jira"
    
  - name: "Keycloak"
    github_url: "https://github.com/keycloak/keycloak"
    owner: "keycloak"
    repo: "keycloak"
    foundation: "CNCF"
    website: "https://www.keycloak.org"
    
  - name: "Apicurio"
    github_url: "https://github.com/Apicurio/apicurio-studio"
    owner: "Apicurio"
    repo: "apicurio-studio"
    foundation: "Independent"
    website: "https://www.apicur.io"
    
  - name: "3scale"
    github_url: "https://github.com/3scale/3scale-operator"
    owner: "3scale"
    repo: "3scale-operator"
    foundation: "Red Hat"
    website: "https://www.3scale.net"
  
  # Example: Project with multiple repositories
  # Pull requests will be aggregated across all repos
  # - name: "Multi-Repo Project"
  #   foundation: "Example Foundation"
  #   website: "https://example.org"
  #   repos:
  #     - owner: "example-org"
  #       repo: "main-repo"
  #     - owner: "example-org"
  #       repo: "secondary-repo"
  #     - owner: "example-org"
  #       repo: "third-repo"

# Data extraction settings
extraction:
  # How many quarters of historical data to fetch
  quarters_back: 8
  
  # Rate limiting (requests per hour)
  rate_limit: 5000
  
  # Retry settings
  max_retries: 3
  retry_delay: 5